{{ 'component-accordion.css' | asset_url | stylesheet_tag }}

<section class="ml-page-hero">
  <p class="ml-label">{{ section.settings.label }}</p>
  <h1>{{ page.title | default: section.settings.heading }}</h1>
  {%- if section.settings.text != blank -%}
    <p class="ml-archive__text">{{ section.settings.text }}</p>
  {%- endif -%}
</section>

<section class="ml-page-body">
  <div class="page-width">
    {%- if page.content != blank -%}
      <article class="ml-page-copy rte">{{ page.content }}</article>
    {%- endif -%}

    {%- for block in section.blocks -%}
      <div class="accordion" {{ block.shopify_attributes }}>
        <details id="Faq-{{ block.id }}">
          <summary id="FaqSummary-{{ block.id }}">
            <h3 class="accordion__title h4">{{ block.settings.question | escape }}</h3>
            {{- 'icon-caret.svg' | inline_asset_content -}}
          </summary>
          <div
            class="accordion__content rte"
            id="FaqContent-{{ block.id }}"
            role="region"
            aria-labelledby="FaqSummary-{{ block.id }}"
          >
            {{ block.settings.answer }}
          </div>
        </details>
      </div>
    {%- endfor -%}
  </div>
</section>

{%- if section.blocks.size > 0 -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {%- for block in section.blocks -%}
          {
            "@type": "Question",
            "name": {{ block.settings.question | strip_newlines | json }},
            "acceptedAnswer": {
              "@type": "Answer",
              "text": {{ block.settings.answer | strip_html | strip_newlines | json }}
            }
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Maison FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Everything you need to know before you order."
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maison FAQ",
      "blocks": [
        {
          "type": "faq_item"
        }
      ]
    }
  ]
}
{% endschema %}
