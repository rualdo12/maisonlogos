<section class="ml-waitlist">
  <p class="ml-label">{{ section.settings.label }}</p>
  <h1>{{ section.settings.heading }}</h1>
  <p class="ml-archive__text">{{ section.settings.text }}</p>

  <div class="ml-newsletter-form">
    {%- form 'customer', id: 'MaisonWaitlist', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter, waitlist">
      <div class="newsletter-form__field-wrapper">
        <div class="field">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="field__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Newsletter-error--{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success--{{ section.id }}"
            {% endif %}
            placeholder="{{ section.settings.placeholder }}"
            required
          >
          <label class="field__label" for="NewsletterForm--{{ section.id }}">
            {{ section.settings.placeholder }}
          </label>
          <button
            type="submit"
            class="newsletter-form__button field__button"
            name="commit"
            id="Subscribe"
            aria-label="{{ section.settings.button_label }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-arrow.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
        {%- if form.errors -%}
          <small class="newsletter-form__message form__message" id="Newsletter-error--{{ section.id }}">
            <span class="svg-wrapper">
              {{- 'icon-error.svg' | inline_asset_content -}}
            </span>
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </small>
        {%- endif -%}
      </div>
      {%- if form.posted_successfully? -%}
        <h2 class="newsletter-form__message newsletter-form__message--success form__message" id="Newsletter-success--{{ section.id }}" tabindex="-1" autofocus>
          <span class="svg-wrapper">
            {{- 'icon-success.svg' | inline_asset_content -}}
          </span>
          {{ section.settings.success_message }}
        </h2>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Maison waitlist",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "WAITLIST"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The next collection will open in its time."
    },
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Leave your email to be notified when the next release is ready."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Join"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "You are on the waitlist."
    }
  ],
  "presets": [
    {
      "name": "Maison waitlist"
    }
  ]
}
{% endschema %}
