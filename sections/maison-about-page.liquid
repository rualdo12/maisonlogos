{%- liquid
  assign story_accent = section.settings.accent_color | default: '#C9A84C'
  assign story_muted  = section.settings.muted_color  | default: '#8C7B6B'
-%}

<article
  class="ml-brand-story color-{{ section.settings.color_scheme }} gradient"
  style="
    --ml-story-accent: {{ story_accent }};
    --ml-story-muted:  {{ story_muted }};
    --ml-story-logo-width:          {{ section.settings.logo_width }}px;
    --ml-story-logo-text-size:      {{ section.settings.logo_text_size }}px;
    --ml-story-label-size:          {{ section.settings.label_text_size }}px;
    --ml-story-cover-heading-size:  {{ section.settings.cover_heading_size }}px;
    --ml-story-subtitle-size:       {{ section.settings.subtitle_size }}px;
    --ml-story-scripture-size:      {{ section.settings.scripture_size }}px;
    --ml-story-chapter-heading-size:{{ section.settings.chapter_heading_size }}px;
    --ml-story-body-size:           {{ section.settings.body_text_size }}px;
    --ml-story-pull-size:           {{ section.settings.pull_quote_size }}px;
    --ml-story-closing-heading-size:{{ section.settings.closing_heading_size }}px;
  "
>

  {%- comment -%} ── COVER ──────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_cover -%}
    <header class="ml-brand-story__cover{% if section.settings.cover_image != blank %} ml-brand-story__cover--split{% endif %}">

      <div class="ml-brand-story__cover-text">
        {%- if section.settings.logo_image != blank -%}
          <div class="ml-brand-story__logo ml-reveal">
            {{
              section.settings.logo_image
              | image_url: width: 1400
              | image_tag:
                widths: '320, 480, 640, 900, 1200, 1400',
                sizes: '(min-width: 750px) 520px, 72vw',
                class: 'ml-brand-story__logo-image',
                loading: 'eager'
            }}
          </div>
        {%- elsif section.settings.brand_label != blank -%}
          <p class="ml-brand-story__logo-text ml-reveal">{{ section.settings.brand_label }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h1 class="ml-reveal ml-reveal--delay-1">{{ section.settings.heading }}</h1>
        {%- endif -%}

        <span class="ml-brand-story__dash ml-reveal ml-reveal--delay-2" aria-hidden="true">&mdash;</span>

        {%- if section.settings.subtitle != blank -%}
          <p class="ml-brand-story__subtitle ml-reveal ml-reveal--delay-2">{{ section.settings.subtitle }}</p>
        {%- endif -%}

        {%- if section.settings.show_scripture -%}
          <div class="ml-brand-story__scripture ml-reveal ml-reveal--delay-3">
            {%- if section.settings.scripture_line_1 != blank -%}<p>{{ section.settings.scripture_line_1 }}</p>{%- endif -%}
            {%- if section.settings.scripture_line_2 != blank -%}<p>{{ section.settings.scripture_line_2 }}</p>{%- endif -%}
            {%- if section.settings.scripture_line_3 != blank -%}<p>{{ section.settings.scripture_line_3 }}</p>{%- endif -%}
            {%- if section.settings.scripture_reference != blank -%}
              <cite>{{ section.settings.scripture_reference }}</cite>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="ml-brand-story__scroll-cue ml-reveal ml-reveal--delay-4" aria-hidden="true">
          <span class="ml-brand-story__scroll-label">Scroll</span>
          <span class="ml-brand-story__scroll-line"></span>
        </div>
      </div>

      {%- if section.settings.cover_image != blank -%}
        <div class="ml-brand-story__cover-image">
          {{
            section.settings.cover_image
            | image_url: width: 2000
            | image_tag:
              widths: '600, 900, 1200, 1600, 2000',
              sizes: '(min-width: 750px) 50vw, 100vw',
              class: 'ml-brand-story__cover-img',
              loading: 'eager'
          }}
          <div class="ml-brand-story__cover-image-overlay"></div>
        </div>
      {%- endif -%}

    </header>
  {%- endif -%}

  {%- comment -%} ── CHAPTERS (always visible) ──────────────────── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="ml-brand-story__body">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'chapter' -%}
            <section
              class="ml-brand-story__chapter{% if block.settings.image != blank %} ml-brand-story__chapter--imaged{% if block.settings.image_position == 'right' %} ml-brand-story__chapter--img-right{% endif %}{% endif %}"
              {{ block.shopify_attributes }}
            >

              {%- if block.settings.image != blank -%}
                <div class="ml-brand-story__chapter-media ml-reveal">
                  {{
                    block.settings.image
                    | image_url: width: 1400
                    | image_tag:
                      widths: '480, 700, 900, 1200, 1400',
                      sizes: '(min-width: 990px) 44vw, 90vw',
                      class: 'ml-brand-story__chapter-img'
                  }}
                </div>
              {%- endif -%}

              <div class="ml-brand-story__chapter-content">
                {%- assign chapter_num = forloop.index | prepend: '0' | slice: -2, 2 -%}
                <span class="ml-brand-story__chapter-num" aria-hidden="true">{{ chapter_num }}</span>

                {%- if block.settings.label != blank -%}
                  <p class="ml-brand-story__label ml-reveal">{{ block.settings.label }}</p>
                {%- endif -%}

                {%- if block.settings.heading != blank -%}
                  <h2 class="ml-reveal ml-reveal--delay-1">{{ block.settings.heading }}</h2>
                {%- endif -%}

                {%- if block.settings.body != blank -%}
                  <div class="ml-brand-story__text rte ml-reveal ml-reveal--delay-2">{{ block.settings.body }}</div>
                {%- endif -%}
              </div>

              {%- if block.settings.pull_quote != blank -%}
                <blockquote class="ml-brand-story__pull ml-reveal">
                  <p>{{ block.settings.pull_quote | newline_to_br }}</p>
                </blockquote>
              {%- endif -%}

              {%- if block.settings.body_after_quote != blank -%}
                <div class="ml-brand-story__text ml-brand-story__text--after rte ml-reveal">{{ block.settings.body_after_quote }}</div>
              {%- endif -%}

            </section>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── CLOSING ────────────────────────────────────── {%- endcomment -%}
  {%- if section.settings.show_closing -%}
    <footer class="ml-brand-story__closing color-{{ section.settings.closing_color_scheme }} gradient">
      {%- if section.settings.closing_heading != blank -%}
        <h2 class="ml-reveal">{{ section.settings.closing_heading }}</h2>
      {%- endif -%}
      {%- if section.settings.closing_subtitle != blank -%}
        <p class="ml-serif ml-reveal ml-reveal--delay-1">{{ section.settings.closing_subtitle }}</p>
      {%- endif -%}
      {%- if section.settings.domain != blank -%}
        <p class="ml-reveal ml-reveal--delay-1">{{ section.settings.domain }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <span class="ml-gold-rule ml-reveal ml-reveal--delay-2"></span>
        <a class="ml-button ml-button--ivory ml-reveal ml-reveal--delay-2" href="{{ section.settings.cta_link }}">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </footer>
  {%- endif -%}

</article>

<script>
  (() => {
    const els = document.querySelectorAll('.ml-reveal');
    if (!els.length) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('ml-reveal--visible');
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12 });
    els.forEach(el => io.observe(el));
  })();
</script>

