      "default": "MAISON LOGOS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "House of the Word"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Brand Story"
