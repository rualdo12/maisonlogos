{% doc %}
  @prompt
    Create a full-width hero/gallery section at the top of the homepage where the merchant can showcase product mockup photos. It should support multiple images displayed in a clean, visually appealing layout (such as a grid or slideshow), with optional captions. Below that, create a brand story section with a rich text area where the merchant can write and format their brand narrative, with an optional heading and a background color setting.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-brand-story-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-brand-story__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-brand-story__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
  }

  .ai-brand-story__content-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-brand-story__content-{{ ai_gen_id }} p {
    margin: 0 0 16px;
  }

  .ai-brand-story__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-brand-story__content-{{ ai_gen_id }} h1,
  .ai-brand-story__content-{{ ai_gen_id }} h2,
  .ai-brand-story__content-{{ ai_gen_id }} h3,
  .ai-brand-story__content-{{ ai_gen_id }} h4,
  .ai-brand-story__content-{{ ai_gen_id }} h5,
  .ai-brand-story__content-{{ ai_gen_id }} h6 {
    margin: 24px 0 12px;
    color: {{ block.settings.heading_color }};
  }

  .ai-brand-story__content-{{ ai_gen_id }} h1:first-child,
  .ai-brand-story__content-{{ ai_gen_id }} h2:first-child,
  .ai-brand-story__content-{{ ai_gen_id }} h3:first-child,
  .ai-brand-story__content-{{ ai_gen_id }} h4:first-child,
  .ai-brand-story__content-{{ ai_gen_id }} h5:first-child,
  .ai-brand-story__content-{{ ai_gen_id }} h6:first-child {
    margin-top: 0;
  }

  .ai-brand-story__content-{{ ai_gen_id }} ul,
  .ai-brand-story__content-{{ ai_gen_id }} ol {
    margin: 0 0 16px;
    padding-left: 24px;
  }

  .ai-brand-story__content-{{ ai_gen_id }} li {
    margin-bottom: 8px;
  }

  .ai-brand-story__content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-brand-story__content-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  .ai-brand-story__content-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  .ai-brand-story__content-{{ ai_gen_id }} em {
    font-style: italic;
  }

  .ai-brand-story__placeholder-{{ ai_gen_id }} {
    padding: 40px;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    text-align: center;
    color: #666;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-brand-story__heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-brand-story__content-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<brand-story-{{ ai_gen_id }} class="ai-brand-story-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-brand-story__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-brand-story__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    {% if block.settings.content != blank %}
      <div class="ai-brand-story__content-{{ ai_gen_id }}">
        {{ block.settings.content }}
      </div>
    {% else %}
      <div class="ai-brand-story__placeholder-{{ ai_gen_id }}">
        Add your brand story using the rich text editor. Share your journey, values, and what makes your brand unique.
      </div>
    {% endif %}
  </div>
</brand-story-{{ ai_gen_id }}>

<script>
  (function() {
    class BrandStory{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('brand-story-{{ ai_gen_id }}', BrandStory{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Brand story",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#2c2c2c"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Spacing below heading",
      "default": 32
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Brand story",
      "default": "<p>Share your brand's journey, values, and what makes you unique. This is your opportunity to connect with customers on a deeper level.</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Text size",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2c2c2c"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#c9a84c"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "min": 600,
      "max": 1200,
      "step": 100,
      "unit": "px",
      "label": "Container width",
      "default": 800
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Brand story"
    }
  ]
}
{% endschema %}
