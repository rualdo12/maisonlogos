{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  /* ----------------------
     Core Section Setup
  ----------------------- */
  .ai-editorial-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    position: relative;
  }

  .ai-editorial__container-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    max-width: 100%;
    margin: 0 auto;
  }

  /* ----------------------
     Left Column: Sticky Visual
  ----------------------- */
  .ai-editorial__visual-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_image_width }}%;
    background-color: {{ block.settings.background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .ai-editorial__visual-inner-{{ ai_gen_id }} {
    position: sticky;
    top: 50vh;
    transform: translateY(-50%);
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .ai-editorial__image-{{ ai_gen_id }} {
    max-width: 100%;
    height: auto;
    object-fit: contain;
  }

  /* ----------------------
     Right Column: Story Text
  ----------------------- */
  .ai-editorial__content-{{ ai_gen_id }} {
    width: {{ 100 | minus: block.settings.desktop_image_width }}%;
    padding: {{ block.settings.padding_top }}px 80px {{ block.settings.padding_bottom }}px 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .ai-editorial__gold-heading-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    font-family: serif;
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.1;
    margin: 0 0 40px 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 400;
  }

  .ai-editorial__richtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.8;
    color: {{ block.settings.text_color }};
  }

  .ai-editorial__richtext-{{ ai_gen_id }} p {
    margin: 0 0 24px 0;
  }

  .ai-editorial__richtext-{{ ai_gen_id }} h3, 
  .ai-editorial__richtext-{{ ai_gen_id }} h4 {
    color: {{ block.settings.text_color }};
    margin: 48px 0 16px 0;
    font-size: 1.1em;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
  }

  .ai-editorial__richtext-{{ ai_gen_id }} strong {
    font-weight: 600;
  }

  /* ----------------------
     Mobile Responsiveness
  ----------------------- */
  @media screen and (max-width: 899px) {
    .ai-editorial__visual-{{ ai_gen_id }},
    .ai-editorial__content-{{ ai_gen_id }} {
      width: 100%;
    }
    
    .ai-editorial__visual-inner-{{ ai_gen_id }} {
      position: relative;
      top: 0;
      transform: none;
    }

    .ai-editorial__visual-{{ ai_gen_id }} {
      padding: 40px 20px 0;
    }

    .ai-editorial__content-{{ ai_gen_id }} {
      padding: 40px 20px {{ block.settings.padding_bottom }}px;
    }

    .ai-editorial__gold-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }

    .ai-editorial__richtext-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<editorial-story-{{ ai_gen_id }} class="ai-editorial-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-editorial__container-{{ ai_gen_id }}">
    
    <div class="ai-editorial__visual-{{ ai_gen_id }}">
      <div class="ai-editorial__visual-inner-{{ ai_gen_id }}">
        {% if block.settings.hero_image != blank %}
          {% assign img_class = "ai-editorial__image-" | append: ai_gen_id %}
          {{ block.settings.hero_image | image_url: width: 1200 | image_tag: class: img_class, loading: 'lazy' }}
        {% else %}
          <div style="font-family: serif; font-size: 8vw; color: {{ block.settings.text_color }}; line-height: 1; text-align: center; letter-spacing: 0.05em; word-break: break-word;">
            MAISON<br>LOGOS
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-editorial__content-{{ ai_gen_id }}">
      
      {% if block.settings.accent_heading != blank %}
        <h2 class="ai-editorial__gold-heading-{{ ai_gen_id }}">{{ block.settings.accent_heading | newline_to_br }}</h2>
      {% endif %}

      {% if block.settings.content != blank %}
        <div class="ai-editorial__richtext-{{ ai_gen_id }}">
          {{ block.settings.content }}
        </div>
      {% endif %}

    </div>

  </div>
</editorial-story-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Editorial Brand Story",
  "settings": [
    {
      "type": "header",
      "content": "Left Column: Hero Graphic"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image / Typography Graphic",
      "info": "Upload the large graphic (like the giant MAISON LOGOS text) to sit on the left."
    },
    {
      "type": "range",
      "id": "desktop_image_width",
      "min": 30,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "Desktop Left Column Width",
      "default": 60
    },
    {
      "type": "header",
      "content": "Right Column: Story Text"
    },
    {
      "type": "textarea",
      "id": "accent_heading",
      "label": "Gold Accent Heading",
      "default": "MAISON\nLOGOS\nSTORY",
      "info": "Use 'Enter' to stack words exactly as you want them."
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 30,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Accent Heading Size",
      "default": 72
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Body Content",
      "default": "<p>MAISON LOGOS<br/>House of the Word</p><p>The Brand Story</p><p>In the beginning was the Word.<br/>And the Word was with God.<br/>And the Word was God.<br/><em>John 1:1</em></p><h3>I. THE QUESTION</h3><p>Every morning, before you speak, before anyone hears your name or knows your story, the world reads you. The cut of what you wear. The weight of the fabric. The restraint of the detail.</p><p>Most people dress to fit in. To be acceptable. To not stand out. But there is a different kind of person. One who has settled a question that most people spend their entire lives avoiding: <em>Who does God say I am?</em></p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Body Text Size",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#0b1626"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body Text Color (White)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Gold)",
      "default": "#C4A464"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 10,
      "unit": "px",
      "label": "Top Padding",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 10,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 120
    }
  ],
  "presets": [
    {
      "name": "Editorial Brand Story"
    }
  ]
}
{% endschema %}